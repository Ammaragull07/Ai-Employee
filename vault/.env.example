# AI Employee Silver Tier - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it is already in .gitignore).

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_api_key_here_sk_ant_...

# Optional: customize the model (default: claude-3-5-sonnet-20241022)
# CLAUDE_MODEL=claude-opus-4-6

# Optional: customize max tokens for responses (default: 300)
# MAX_TOKENS=300

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Step 1: Create a LinkedIn Developer App at https://www.linkedin.com/developers/
# Step 2: Add OAuth 2.0 scopes: openid, profile, w_member_social
# Step 3: Generate an access token via the Token Generator tool in the Dev portal
# Step 4: Find your Person URN:
#         curl -H "Authorization: Bearer YOUR_TOKEN" https://api.linkedin.com/v2/me
#         The "id" field is your person ID. Prepend "urn:li:person:"

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# Optional: post as a company page instead of your personal profile
# LINKEDIN_ORG_URN=urn:li:organization:YOUR_ORG_ID

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Gmail uses credentials.json + token.json (OAuth2 Desktop App flow).
# 1. credentials.json is already in this directory.
# 2. Run once: python gmail_watcher.py --setup   (opens browser)
# 3. token.json is saved automatically — no secret needed here.

# ── General ───────────────────────────────────────────────────────────────────
# Set to true during development to skip real external API calls
DRY_RUN=false

# Gmail sender address (filled automatically after --setup, but can override here)
# GMAIL_SENDER=your@gmail.com
